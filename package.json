{
  "name": "media-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Open source TypeScript engine for unified media metadata search and aggregation.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:check": "node scripts/check-package-builds.mjs seed && pnpm build && node scripts/check-package-builds.mjs verify",
    "benchmark:imdb-dataset": "pnpm --filter @media-engine/providers build && node --expose-gc scripts/imdb-dataset-benchmark.mjs",
    "benchmark:imdb-dataset:sqlite": "pnpm --filter @media-engine/providers build && node --expose-gc scripts/imdb-dataset-sqlite-benchmark.mjs",
    "dev:api": "pnpm --filter @media-engine/api start:dev",
    "dev:compose": "docker compose up",
    "dev:compose:down": "docker compose down",
    "dev:example": "pnpm --filter @media-engine/example dev",
    "coverage": "pnpm build:check && pnpm coverage:unit",
    "coverage:unit": "pnpm -r --if-present coverage:unit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --filter @media-engine/api lint && pnpm --filter @media-engine/example lint",
    "pack:check": "pnpm build:check && pnpm pack:verify",
    "pack:verify": "node scripts/check-release-consistency.mjs && node scripts/check-package-tarballs.mjs",
    "release:check": "pnpm format:check && pnpm build:check && pnpm lint && pnpm typecheck && pnpm coverage:unit && pnpm test:scripts && pnpm test:e2e && pnpm pack:verify",
    "smoke:availability": "pnpm build && node scripts/availability-smoke.mjs",
    "smoke:availability-latency": "pnpm build && node scripts/availability-latency-smoke.mjs",
    "smoke:details-latency": "pnpm build && node scripts/details-latency-smoke.mjs",
    "smoke:latency": "pnpm build && node scripts/search-latency-smoke.mjs",
    "smoke:merge-performance": "pnpm build && node scripts/merge-performance-smoke.mjs",
    "smoke:search-quality": "pnpm build && node scripts/search-quality-smoke.mjs",
    "smoke:search-quality:full": "pnpm build && node scripts/search-quality-smoke.mjs --matrix full --strict",
    "smoke:search-quality:quick": "pnpm build && node scripts/search-quality-smoke.mjs --matrix quick --strict",
    "smoke:search-quality:scheduled": "pnpm build && node scripts/search-quality-smoke.mjs --matrix full --max-warnings 4 --json",
    "smoke:source-filter-audit": "pnpm build && node scripts/source-filter-audit.mjs",
    "smoke:torrents": "pnpm build && node scripts/torrent-source-smoke.mjs",
    "smoke:providers": "pnpm build && node scripts/provider-smoke.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm build:check && pnpm test:unit && pnpm test:scripts",
    "test:e2e": "pnpm --filter @media-engine/api test:e2e",
    "test:scripts": "node --test scripts/smoke-policy.test.mjs",
    "test:unit": "pnpm -r --if-present test:unit"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
