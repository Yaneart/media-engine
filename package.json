{
  "name": "media-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Open source TypeScript engine for unified media metadata search and aggregation.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @media-engine/api start:dev",
    "dev:compose": "docker compose up",
    "dev:compose:down": "docker compose down",
    "dev:example": "pnpm --filter @media-engine/example dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
