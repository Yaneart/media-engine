{
  "name": "media-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Open source TypeScript engine for unified media metadata search and aggregation.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @media-engine/api start:dev",
    "dev:compose": "docker compose up",
    "dev:compose:down": "docker compose down",
    "dev:example": "pnpm --filter @media-engine/example dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:check": "pnpm build && pnpm --filter @media-engine/core pack --dry-run && pnpm --filter @media-engine/providers pack --dry-run && pnpm --filter @media-engine/sdk pack --dry-run",
    "release:check": "pnpm format:check && pnpm build && pnpm typecheck && pnpm test",
    "smoke:availability": "pnpm build && node scripts/availability-smoke.mjs",
    "smoke:availability-latency": "pnpm build && node scripts/availability-latency-smoke.mjs",
    "smoke:latency": "pnpm build && node scripts/search-latency-smoke.mjs",
    "smoke:providers": "pnpm build && node scripts/provider-smoke.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
