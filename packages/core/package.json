{
  "name": "@media-engine/core",
  "version": "0.0.0",
  "description": "Core TypeScript engine for Media Engine.",
  "license": "MIT",
  "homepage": "https://github.com/Yaneart/media-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Yaneart/media-engine.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Yaneart/media-engine/issues"
  },
  "keywords": [
    "media",
    "metadata",
    "movies",
    "series",
    "anime",
    "shikimori"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test dist/providers/registry.test.js dist/errors/types.test.js dist/merge/strategy.test.js dist/cache/memory.test.js dist/engine/engine.test.js dist/testing/providers.test.js dist/streaming/types.test.js"
  }
}
