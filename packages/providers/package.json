{
  "name": "@media-engine/providers",
  "version": "0.1.1",
  "description": "Provider implementations for Media Engine.",
  "license": "MIT",
  "homepage": "https://github.com/Yaneart/media-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Yaneart/media-engine.git",
    "directory": "packages/providers"
  },
  "bugs": {
    "url": "https://github.com/Yaneart/media-engine/issues"
  },
  "keywords": [
    "media",
    "metadata",
    "movies",
    "series",
    "anime",
    "aniliberty",
    "ddbb",
    "hls",
    "kinobd",
    "cinemeta",
    "imdb",
    "shikimori",
    "anilist",
    "tvmaze",
    "wikidata",
    "no-token",
    "torrent",
    "yts"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*test-helpers.d.ts",
    "!dist/**/*test-helpers.js",
    "!dist/**/*test-helpers.js.map",
    "!dist/kodik",
    "!dist/tmdb",
    "README.md",
    "README.ru.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.mjs",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "coverage": "pnpm build && pnpm coverage:unit",
    "coverage:unit": "node ../../scripts/run-node-tests.mjs --coverage --lines=92 --branches=80 --functions=96",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && pnpm test:unit",
    "test:unit": "node ../../scripts/run-node-tests.mjs"
  },
  "dependencies": {
    "@media-engine/core": "workspace:*"
  }
}
