{
  "name": "@media-engine/providers",
  "version": "0.0.0",
  "description": "Provider implementations for Media Engine.",
  "license": "MIT",
  "homepage": "https://github.com/Yaneart/media-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Yaneart/media-engine.git",
    "directory": "packages/providers"
  },
  "bugs": {
    "url": "https://github.com/Yaneart/media-engine/issues"
  },
  "keywords": [
    "media",
    "metadata",
    "movies",
    "series",
    "anime",
    "kinobd",
    "cinemeta",
    "imdb",
    "shikimori",
    "anilist",
    "wikidata",
    "no-token"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test dist/shared/http.test.js dist/kinobd/index.test.js dist/cinemeta/index.test.js dist/shikimori/index.test.js dist/anilist/index.test.js dist/wikidata/index.test.js dist/imdb-dataset/index.test.js dist/experimental-streaming/index.test.js dist/kinobd-streaming/index.test.js dist/flixhq-streaming/index.test.js"
  },
  "dependencies": {
    "@media-engine/core": "workspace:*"
  }
}
