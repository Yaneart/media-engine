{
  "name": "@media-engine/sdk",
  "version": "0.1.1",
  "description": "Typed HTTP SDK for Media Engine API clients.",
  "license": "MIT",
  "homepage": "https://github.com/Yaneart/media-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Yaneart/media-engine.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Yaneart/media-engine/issues"
  },
  "keywords": [
    "media",
    "metadata",
    "movies",
    "series",
    "anime",
    "torrent",
    "sdk",
    "api-client"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "README.md",
    "README.ru.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.mjs",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "coverage": "pnpm build && pnpm coverage:unit",
    "coverage:unit": "node ../../scripts/run-node-tests.mjs --coverage --lines=95 --branches=88 --functions=95",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && pnpm test:unit",
    "test:unit": "node ../../scripts/run-node-tests.mjs"
  },
  "dependencies": {
    "@media-engine/core": "workspace:*"
  }
}
