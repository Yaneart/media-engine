# EN: Local API host. Leave empty to use the default 127.0.0.1.
# RU: Локальный host API. Оставь пустым, чтобы использовать 127.0.0.1 по умолчанию.
HOST=127.0.0.1

# EN: Local API port. Leave empty to use the default 3000.
# RU: Локальный порт API. Оставь пустым, чтобы использовать 3000 по умолчанию.
PORT=3000

# EN: Optional TMDB read access token. If empty, TMDB provider is disabled.
# RU: Опциональный read access token TMDB. Если пусто, TMDB provider отключен.
TMDB_API_READ_ACCESS_TOKEN=

# EN: Legacy/local fallback accepted by the API config.
# RU: Старый/локальный fallback, который принимает API config.
TMDB_API_KEY=
